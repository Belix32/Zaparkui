# Supabase Configuration
# For local development, copy this file to .env and fill in your values

# Vite/Vercel compatible keys
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin configuration
VITE_ADMIN_EMAIL=your_admin_email@example.com

# Alternative Next.js format (for reference)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# NEXT_PUBLIC_SUPABASE_PUBLISHED_KEY=your_supabase_anon_key

# YooKassa (ЮKassa) Payment Integration
# Leave empty to use mock mode for development
VITE_YOOKASSA_SHOP_ID=
VITE_YOOKASSA_SECRET_KEY=