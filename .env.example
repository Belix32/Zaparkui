# Supabase Configuration for Запаркуй (Zaparkyi)
#
# Get your credentials from Supabase Dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the URL and anon key
#
# NOTE: Uses NEXT_PUBLIC_ prefix for Vercel/Next.js compatibility
# Works with Vite as well via import.meta.env.NEXT_PUBLIC_*

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here